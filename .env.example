# =====================================================================
# KIZUNA GEEK — Variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA commite `.env` no repositório.
# =====================================================================

# ============ DATABASE (Supabase) ============
# Connection pooling (PgBouncer) — porta 6543 — usado em runtime pelo Prisma Client
DATABASE_URL="postgresql://postgres.SEU_PROJETO:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Conexão direta — porta 5432 — usado apenas por `prisma migrate` e `prisma db push`
DIRECT_URL="postgresql://postgres.SEU_PROJETO:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ============ AUTH.JS v5 ============
# Gere com: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============ STRIPE ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ============ MELHOR ENVIO ============
# Crie um app em https://sandbox.melhorenvio.com.br/painel/gerenciar/tokens (sandbox)
# ou https://www.melhorenvio.com.br/painel/gerenciar/tokens (prod)
MELHOR_ENVIO_CLIENT_ID=
MELHOR_ENVIO_CLIENT_SECRET=
MELHOR_ENVIO_REDIRECT_URI=http://localhost:3000/api/melhor-envio/callback
# Token gerado direto no painel (atalho para desenvolvimento, antes do fluxo OAuth completo)
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_SANDBOX=true
# CEP de origem (loja em Itapetininga/SP)
MELHOR_ENVIO_ORIGIN_ZIPCODE=18200000

# ============ FOCUS NFE ============
# Token de produção/homologação (https://focusnfe.com.br)
FOCUS_NFE_TOKEN=
FOCUS_NFE_SANDBOX=true

# ============ RESEND (EMAIL) ============
RESEND_API_KEY=
EMAIL_FROM="Kizuna Geek <contato@kizunageek.com.br>"

# ============ UPLOAD (UploadThing) ============
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ============ APP ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
